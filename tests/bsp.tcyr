# bsp.tcyr -- BSP library test suite
# Run: cyrb test tests/bsp.tcyr
#   or: cat tests/bsp.tcyr | cc2 > build/test && chmod +x build/test && ./build/test

include "lib/string.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/fmt.cyr"
include "lib/assert.cyr"

include "src/lib.cyr"

fn main() {
    alloc_init();

    # ============================================================
    test_group("fixed-point basics");
    # ============================================================

    assert_eq(fx_from_int(1), 65536, "from_int(1)");
    assert_eq(fx_from_int(0), 0, "from_int(0)");
    assert_eq(fx_from_int(100), 6553600, "from_int(100)");

    assert_eq(fx_to_int(65536), 1, "to_int(1.0)");
    assert_eq(fx_to_int(131072), 2, "to_int(2.0)");
    assert_eq(fx_to_int(32768), 0, "to_int(0.5) truncates");
    assert_eq(fx_to_int(0), 0, "to_int(0)");

    # ============================================================
    test_group("fixed-point arithmetic");
    # ============================================================

    var a = fx_from_int(10);
    var b = fx_from_int(3);

    assert_eq(fx_to_int(fx_mul(a, b)), 30, "10 * 3 = 30");
    assert_eq(fx_to_int(fx_div(a, b)), 3, "10 / 3 = 3 (truncated)");
    assert_eq(fx_to_int(fx_mul(fx_from_int(7), fx_from_int(6))), 42, "7 * 6 = 42");

    # Division by zero
    assert_eq(fx_div(a, 0), FX_MAX, "div by zero = MAX");

    # Abs
    var neg5a = fx_from_int(0 - 5);
    assert_eq(fx_to_int(fx_abs(neg5a)), 5, "abs(-5) = 5");
    assert_eq(fx_to_int(fx_abs(a)), 10, "abs(10) = 10");
    assert_eq(fx_abs(0), 0, "abs(0) = 0");

    # Min/max
    assert_eq(fx_min(a, b), b, "min(10, 3) = 3");
    assert_eq(fx_max(a, b), a, "max(10, 3) = 10");

    # Clamp
    assert_eq(fx_clamp(a, 0, fx_from_int(5)), fx_from_int(5), "clamp(10, 0, 5) = 5");
    assert_eq(fx_clamp(b, 0, a), b, "clamp(3, 0, 10) = 3");

    # ============================================================
    test_group("AABB construction");
    # ============================================================

    var box[32];
    aabb_init(&box);
    aabb_add_point(&box, fx_from_int(10), fx_from_int(20));
    aabb_add_point(&box, fx_from_int(30), fx_from_int(40));

    assert_eq(fx_to_int(aabb_width(&box)), 20, "width 30-10=20");
    assert_eq(fx_to_int(aabb_height(&box)), 20, "height 40-20=20");
    assert_eq(fx_to_int(aabb_center_x(&box)), 20, "center_x (10+30)/2=20");
    assert_eq(fx_to_int(aabb_center_y(&box)), 30, "center_y (20+40)/2=30");

    # Expand with another point
    aabb_add_point(&box, fx_from_int(0), fx_from_int(0));
    assert_eq(fx_to_int(aabb_width(&box)), 30, "expanded width 30-0=30");
    assert_eq(fx_to_int(aabb_height(&box)), 40, "expanded height 40-0=40");

    # ============================================================
    test_group("AABB containment");
    # ============================================================

    var box2[32];
    aabb_set(&box2, fx_from_int(100), fx_from_int(0), fx_from_int(0), fx_from_int(100));

    assert_eq(aabb_contains_point(&box2, fx_from_int(50), fx_from_int(50)), 1, "center inside");
    assert_eq(aabb_contains_point(&box2, fx_from_int(0), fx_from_int(0)), 1, "corner inside");
    assert_eq(aabb_contains_point(&box2, fx_from_int(100), fx_from_int(100)), 1, "far corner inside");
    assert_eq(aabb_contains_point(&box2, fx_from_int(101), fx_from_int(50)), 0, "right outside");
    assert_eq(aabb_contains_point(&box2, fx_from_int(50), fx_from_int(101)), 0, "top outside");
    assert_eq(aabb_contains_point(&box2, fx_from_int(0 - 1), fx_from_int(50)), 0, "left outside");

    # ============================================================
    test_group("AABB intersection");
    # ============================================================

    var a_box[32];
    var b_box[32];
    aabb_set(&a_box, fx_from_int(20), fx_from_int(0), fx_from_int(0), fx_from_int(20));
    aabb_set(&b_box, fx_from_int(30), fx_from_int(10), fx_from_int(10), fx_from_int(30));
    assert_eq(aabb_intersects(&a_box, &b_box), 1, "overlapping boxes");

    aabb_set(&b_box, fx_from_int(50), fx_from_int(40), fx_from_int(40), fx_from_int(50));
    assert_eq(aabb_intersects(&a_box, &b_box), 0, "separated boxes");

    # Touching edge
    aabb_set(&b_box, fx_from_int(30), fx_from_int(20), fx_from_int(0), fx_from_int(20));
    assert_eq(aabb_intersects(&a_box, &b_box), 1, "touching edge");

    # ============================================================
    test_group("AABB merge");
    # ============================================================

    var m1[32];
    var m2[32];
    aabb_set(&m1, fx_from_int(10), fx_from_int(0), fx_from_int(0), fx_from_int(10));
    aabb_set(&m2, fx_from_int(20), fx_from_int(5), fx_from_int(5), fx_from_int(20));
    aabb_merge(&m1, &m2);
    assert_eq(fx_to_int(aabb_width(&m1)), 20, "merged width 0-20=20");
    assert_eq(fx_to_int(aabb_height(&m1)), 20, "merged height 0-20=20");

    # ============================================================
    test_group("point-on-side");
    # ============================================================

    # Horizontal line going right from origin
    var zero = fx_from_int(0);
    var one = fx_from_int(1);
    var five = fx_from_int(5);
    var neg5 = fx_from_int(0 - 5);

    var s1 = bsp_point_side(zero, five, zero, zero, one, zero);
    var s2 = bsp_point_side(zero, neg5, zero, zero, one, zero);
    assert_neq(s1, s2, "above vs below horizontal line");

    # Vertical line going up from origin
    var s3 = bsp_point_side(five, zero, zero, zero, zero, one);
    var s4 = bsp_point_side(neg5, zero, zero, zero, zero, one);
    assert_neq(s3, s4, "right vs left of vertical line");

    # Point on the line
    var s5 = bsp_point_side(five, zero, zero, zero, one, zero);
    assert_eq(s5, 0, "point on line = right/front");

    # ============================================================
    test_group("segment intersection");
    # ============================================================

    # Crossing X: (0,0)-(10,10) vs (0,10)-(10,0)
    var o = fx_from_int(0);
    var ten = fx_from_int(10);
    assert_eq(bsp_seg_intersect(o, o, ten, ten, o, ten, ten, o), 1, "crossing segments");

    # Parallel horizontal: (0,0)-(10,0) vs (0,5)-(10,5)
    assert_eq(bsp_seg_intersect(o, o, ten, o, o, five, ten, five), 0, "parallel horizontal");

    # T-intersection: (5,0)-(5,10) vs (0,5)-(10,5)
    assert_eq(bsp_seg_intersect(five, o, five, ten, o, five, ten, five), 1, "T intersection");

    # Non-touching: (0,0)-(5,0) vs (6,0)-(10,0)
    var six = fx_from_int(6);
    assert_eq(bsp_seg_intersect(o, o, five, o, six, o, ten, o), 0, "collinear non-touching");

    # Near miss: (0,0)-(4,4) vs (5,0)-(5,3)
    var four = fx_from_int(4);
    var three = fx_from_int(3);
    assert_eq(bsp_seg_intersect(o, o, four, four, five, o, five, three), 0, "near miss");

    # ============================================================
    test_group("ray cast");
    # ============================================================

    # Ray from (0,5) going right, hitting segment (5,0)-(5,10)
    var ray_t = bsp_ray_cast(o, five, one, o, five, o, five, ten);
    assert(ray_t > 0, "ray hits wall");

    # Ray from (0,5) going left (negative X), should miss wall at x=5
    var neg1 = fx_from_int(0 - 1);
    var ray_miss = bsp_ray_cast(o, five, neg1, o, five, o, five, ten);
    assert(ray_miss <= 0, "ray going away misses or at origin");

    # ============================================================
    test_group("point-to-segment distance");
    # ============================================================

    # Point (5,5) to segment (0,0)-(10,0) = distance 5
    var dist = bsp_point_seg_dist(five, five, o, o, ten, o);
    var dist_int = fx_to_int(dist);
    assert(dist_int >= 4, "dist >= 4");
    assert(dist_int <= 6, "dist <= 6");

    # Point on segment
    var dist2 = bsp_point_seg_dist(five, o, o, o, ten, o);
    assert_eq(fx_to_int(dist2), 0, "point on segment = 0");

    # Point at endpoint
    var dist3 = bsp_point_seg_dist(o, o, o, o, ten, o);
    assert_eq(fx_to_int(dist3), 0, "point at endpoint = 0");

    # ============================================================
    test_group("negative-coord / signed-shift correctness (1.1.0)");
    # ============================================================

    # aabb_center across origin — exercises `>> 1` on a possibly-negative
    # sum. Pre-1.1.0 used bare `>>` which gave INT64_MAX for negatives.
    var nbox[4];
    aabb_set(&nbox, 3, -5, -5, 3);
    assert_eq(aabb_center_x(&nbox), -1, "center_x(-5,3) = -1 (not INT64_MAX)");
    assert_eq(aabb_center_y(&nbox), -1, "center_y(-5,3) = -1 (not INT64_MAX)");

    aabb_set(&nbox, 10, -10, -20, 20);
    assert_eq(aabb_center_x(&nbox), 0, "center_x(-20,20) = 0");
    assert_eq(aabb_center_y(&nbox), 0, "center_y(-10,10) = 0");

    # point_seg_dist symmetry: equidistant points either side of a seg
    # must return the same distance. Pre-1.1.0 degenerate path returned
    # |p - sx1| regardless of which side, breaking symmetry.
    var d_left = bsp_point_seg_dist(-257, 0, 0, 0, 257, 0);
    var d_right = bsp_point_seg_dist(514, 0, 0, 0, 257, 0);
    assert_eq(d_left, d_right, "point_seg_dist symmetric on sub-precision seg");

    # ============================================================
    test_group("BSP tree accessors");
    # ============================================================

    assert_eq(bsp_is_subsector(0x8000), 1, "subsector flag set");
    assert_eq(bsp_is_subsector(0x8001), 1, "subsector flag + index");
    assert_eq(bsp_is_subsector(0x0001), 0, "no subsector flag");
    assert_eq(bsp_is_subsector(0), 0, "zero = not subsector");
    assert_eq(bsp_subsector_idx(0x8005), 5, "extract subsector index 5");
    assert_eq(bsp_subsector_idx(0x8000), 0, "extract subsector index 0");

    # Node set/get
    var nodes = alloc(BSP_NODE_SIZE * 2);
    bsp_node_set(nodes, 0, fx_from_int(100), fx_from_int(200), fx_from_int(1), fx_from_int(0));
    assert_eq(fx_to_int(bsp_node_x(nodes, 0)), 100, "node x");
    assert_eq(fx_to_int(bsp_node_y(nodes, 0)), 200, "node y");
    assert_eq(fx_to_int(bsp_node_dx(nodes, 0)), 1, "node dx");
    assert_eq(fx_to_int(bsp_node_dy(nodes, 0)), 0, "node dy");

    bsp_node_set_children(nodes, 0, 1, 0x8000);
    assert_eq(bsp_node_child_r(nodes, 0), 1, "right child = node 1");
    assert_eq(bsp_node_child_l(nodes, 0), 0x8000, "left child = subsector 0");

    # ============================================================
    test_group("BSP traversal");
    # ============================================================

    # Build a simple 2-node tree:
    #   Node 0: vertical split at x=500, children: node 1 (right), ss 0 (left)
    #   Node 1: vertical split at x=800, children: ss 1 (right), ss 2 (left)
    var tree = alloc(BSP_NODE_SIZE * 2);
    bsp_node_set(tree, 0, fx_from_int(500), fx_from_int(0), fx_from_int(0), fx_from_int(1));
    bsp_node_set_children(tree, 0, 1, 0x8000);

    bsp_node_set(tree, 1, fx_from_int(800), fx_from_int(0), fx_from_int(0), fx_from_int(1));
    bsp_node_set_children(tree, 1, 0x8001, 0x8002);

    # Root = node_count-1 = node 1 (split at x=800)
    # Node 1 left child = 0x8002 (subsector 2), right child = 0x8001 (subsector 1)
    # Node 0 is child of... wait, node 1's children are both subsectors.
    # Node 0's right child = 1 (node 1), left child = 0x8000 (ss 0)
    # But root is node 1, so node 0 is never the root!
    # Fix: root should be node 0. Use node_count=2, root=node 1.
    # Actually: tree traversal starts at node_count-1 = 1.
    # So the tree as constructed has node 1 as root.
    # Reinterpret: root splits at x=800
    #   x<800 -> left -> ss 2
    #   x>800 -> right -> ss 1
    # Node 0 is orphaned! Need to fix tree structure.

    # Rebuild: root=node 1 splits at x=500. children: node 0 (right), ss 0 (left)
    #          node 0 splits at x=800. children: ss 1 (right), ss 2 (left)
    bsp_node_set(tree, 1, fx_from_int(500), fx_from_int(0), fx_from_int(0), fx_from_int(1));
    bsp_node_set_children(tree, 1, 0, 0x8000);
    bsp_node_set(tree, 0, fx_from_int(800), fx_from_int(0), fx_from_int(0), fx_from_int(1));
    bsp_node_set_children(tree, 0, 0x8001, 0x8002);

    # x=100: root(node 1, split 500) -> left -> ss 0
    var ss0 = bsp_find_subsector(tree, 2, fx_from_int(100), fx_from_int(50));
    assert_eq(ss0, 0, "x=100 -> subsector 0");

    # x=600: root -> right -> node 0(split 800) -> left -> ss 2
    var ss2 = bsp_find_subsector(tree, 2, fx_from_int(600), fx_from_int(50));
    assert_eq(ss2, 2, "x=600 -> subsector 2");

    # x=900: root -> right -> node 0 -> right -> ss 1
    var ss1 = bsp_find_subsector(tree, 2, fx_from_int(900), fx_from_int(50));
    assert_eq(ss1, 1, "x=900 -> subsector 1");

    # ============================================================
    test_group("blockmap");
    # ============================================================

    # 8x8 grid, cell size 128 units, origin at (0,0)
    var bm_size = 40 + 64 * 136;
    var bm = alloc(bm_size);
    blockmap_init(bm, o, o, fx_from_int(128), 8, 8);

    # Insert segment at (100,100)-(200,100)
    var p100 = fx_from_int(100);
    var p200 = fx_from_int(200);
    blockmap_insert_seg(bm, 7, p100, p100, p200, p100);

    # Cell (0,0) = 0..128 range, should contain the segment
    var cell = blockmap_get_cell(bm, 0, 0);
    assert_eq(blockmap_cell_count(cell), 1, "cell(0,0) has 1 seg");
    assert_eq(blockmap_cell_seg(cell, 0), 7, "cell(0,0) seg idx=7");

    # Cell (1,0) = 128..256 range, should also contain it
    var cell2 = blockmap_get_cell(bm, 1, 0);
    assert_eq(blockmap_cell_count(cell2), 1, "cell(1,0) has 1 seg");

    # Cell (3,3) = far away, should be empty
    var cell3 = blockmap_get_cell(bm, 3, 3);
    assert_eq(blockmap_cell_count(cell3), 0, "cell(3,3) empty");

    # Query by point
    var results = alloc(128);
    var n = blockmap_query_point(bm, p100, p100, fx_from_int(10), results, 16);
    assert_eq(n, 1, "query near (100,100) finds 1");
    assert_eq(load64(results), 7, "query result is seg 7");

    var n2 = blockmap_query_point(bm, fx_from_int(500), fx_from_int(500), fx_from_int(10), results, 16);
    assert_eq(n2, 0, "query far away finds 0");

    # ============================================================
    test_group("line-of-sight");
    # ============================================================

    # Build wall array: one wall at x=5, from y=0 to y=10
    var walls = alloc(32);
    store64(walls, five);
    store64(walls + 8, o);
    store64(walls + 16, five);
    store64(walls + 24, ten);

    var flags = alloc(8);
    store64(flags, 0);

    # (0,5) to (10,5): blocked by wall at x=5
    assert_eq(bsp_check_sight(o, five, ten, five, walls, 1, flags), 0, "sight blocked by wall");

    # (0,5) to (3,5): no wall in the way
    assert_eq(bsp_check_sight(o, five, three, five, walls, 1, flags), 1, "sight clear before wall");

    # Mark wall as two-sided (doesn't block sight)
    store64(flags, 1);
    assert_eq(bsp_check_sight(o, five, ten, five, walls, 1, flags), 1, "two-sided wall doesn't block");

    # ============================================================
    test_group("spatial queries (query.cyr)");
    # ============================================================

    # nearest_seg: two degenerate (point) segments. Both lie farther from
    # the origin than the pre-1.2.0 sentinel 2147483647 (=2^31-1, ~32768.0
    # world units), which the older code never beat -> it returned seg 0
    # (the FARTHER one). The 1.2.0 INT64_MAX seed restores correct selection.
    var qsegs = alloc(64);
    store64(qsegs,      fx_from_int(60000)); store64(qsegs + 8,  fx_from_int(60000));
    store64(qsegs + 16, fx_from_int(60000)); store64(qsegs + 24, fx_from_int(60000));
    store64(qsegs + 32, fx_from_int(40000)); store64(qsegs + 40, fx_from_int(40000));
    store64(qsegs + 48, fx_from_int(40000)); store64(qsegs + 56, fx_from_int(40000));

    assert_eq(bsp_nearest_seg(0, 0, qsegs, 2), 1, "nearest_seg far query picks nearer seg (1.2.0 INT64_MAX sentinel)");
    assert_eq(bsp_nearest_seg(fx_from_int(41000), fx_from_int(41000), qsegs, 2), 1, "nearest_seg picks closer of two (in-range)");
    assert_eq(bsp_nearest_seg(0, 0, qsegs, 0), -1, "nearest_seg empty = -1");

    # count_in_aabb: 16 bytes per entity (x, y). Box [0,100]x[0,100].
    var ents = alloc(48);
    store64(ents,      fx_from_int(50));  store64(ents + 8,  fx_from_int(50));
    store64(ents + 16, fx_from_int(150)); store64(ents + 24, fx_from_int(150));
    store64(ents + 32, fx_from_int(10));  store64(ents + 40, fx_from_int(10));
    var qbox[32];
    aabb_set(&qbox, fx_from_int(100), fx_from_int(0), fx_from_int(0), fx_from_int(100));
    assert_eq(bsp_count_in_aabb(&qbox, ents, 3), 2, "count_in_aabb = 2 of 3 inside");
    assert_eq(bsp_count_in_aabb(&qbox, ents, 0), 0, "count_in_aabb empty = 0");

    # point_in_subsector: CCW unit box [0,10]^2, interior vs exterior point.
    var psegs = alloc(128);
    store64(psegs,       fx_from_int(0));  store64(psegs + 8,   fx_from_int(0));
    store64(psegs + 16,  fx_from_int(10)); store64(psegs + 24,  fx_from_int(0));
    store64(psegs + 32,  fx_from_int(10)); store64(psegs + 40,  fx_from_int(0));
    store64(psegs + 48,  fx_from_int(10)); store64(psegs + 56,  fx_from_int(10));
    store64(psegs + 64,  fx_from_int(10)); store64(psegs + 72,  fx_from_int(10));
    store64(psegs + 80,  fx_from_int(0));  store64(psegs + 88,  fx_from_int(10));
    store64(psegs + 96,  fx_from_int(0));  store64(psegs + 104, fx_from_int(10));
    store64(psegs + 112, fx_from_int(0));  store64(psegs + 120, fx_from_int(0));
    assert_eq(bsp_point_in_subsector(fx_from_int(5), fx_from_int(5), psegs, 4), 1, "point inside convex box");
    assert_eq(bsp_point_in_subsector(fx_from_int(15), fx_from_int(5), psegs, 4), 0, "point outside convex box");

    # ============================================================
    test_group("view frustum (frustum.cyr)");
    # ============================================================

    # Viewer at origin looking down +X, 90 deg FOV (half = 45 deg).
    # cos45 = sin45 = round(0.70710678 * 65536) = 46341.
    var fr = alloc(48);
    frustum_build(fr, 0, 0, 46341, 46341, 46341, -46341);

    assert_eq(frustum_test_point(fr, fx_from_int(100), 0), 1, "point straight ahead is inside");
    assert_eq(frustum_test_point(fr, fx_from_int(-100), 0), 0, "point behind viewer is outside");
    assert_eq(frustum_test_point(fr, fx_from_int(100), fx_from_int(40)), 1, "point ahead-left inside 45 deg");
    assert_eq(frustum_test_point(fr, fx_from_int(100), fx_from_int(-40)), 1, "point ahead-right inside 45 deg");
    assert_eq(frustum_test_point(fr, 0, fx_from_int(100)), 0, "point straight up at edge is outside");

    # frustum_test_aabb is a CONSERVATIVE 4-corner test: it rejects only when
    # all 4 corners fail the SAME half-plane. A box dead ahead is accepted; a
    # box up high (all corners past the left plane) is rejected; a box fully
    # behind is NOT rejected (corners fail different planes) -- documented
    # conservative behavior, not a bug. These lock in frustum_test_aabb's
    # output across the 1.2.0 product-hoist refactor.
    var fbox_ahead[32];
    aabb_set(&fbox_ahead, fx_from_int(50), fx_from_int(-50), fx_from_int(50), fx_from_int(150));
    assert_eq(frustum_test_aabb(fr, &fbox_ahead), 1, "aabb dead ahead is visible");

    var fbox_high[32];
    aabb_set(&fbox_high, fx_from_int(200), fx_from_int(100), fx_from_int(-50), fx_from_int(50));
    assert_eq(frustum_test_aabb(fr, &fbox_high), 0, "aabb high above is culled");

    var fbox_behind[32];
    aabb_set(&fbox_behind, fx_from_int(50), fx_from_int(-50), fx_from_int(-150), fx_from_int(-50));
    assert_eq(frustum_test_aabb(fr, &fbox_behind), 1, "aabb behind: conservative pass (not culled)");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
